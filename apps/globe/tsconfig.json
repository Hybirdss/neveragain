{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@namazue/contracts": ["../../packages/contracts/index.ts"],
      "@namazue/contracts/*": ["../../packages/contracts/*"],
      "@namazue/db": ["../../packages/db/index.ts"],
      "@namazue/db/*": ["../../packages/db/*"],
      "@namazue/domain-earthquake": ["../../packages/domain-earthquake/index.ts"],
      "@namazue/domain-earthquake/*": ["../../packages/domain-earthquake/*"],
      "@namazue/domain-ops": ["../../packages/domain-ops/index.ts"],
      "@namazue/domain-ops/*": ["../../packages/domain-ops/*"],
      "@namazue/domain-replay": ["../../packages/domain-replay/index.ts"],
      "@namazue/domain-replay/*": ["../../packages/domain-replay/*"],
      "@namazue/domain-scenario": ["../../packages/domain-scenario/index.ts"],
      "@namazue/domain-scenario/*": ["../../packages/domain-scenario/*"],
      "@namazue/kernel": ["../../packages/kernel/index.ts"],
      "@namazue/kernel/*": ["../../packages/kernel/*"],
      "@namazue/ops": ["../../packages/ops/index.ts"],
      "@namazue/ops/*": ["../../packages/ops/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
