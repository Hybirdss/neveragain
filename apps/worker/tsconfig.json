{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@namazue/db": ["../../packages/db/index.ts"],
      "@namazue/db/*": ["../../packages/db/*"],
      "@namazue/ops": ["../../packages/ops/index.ts"],
      "@namazue/ops/*": ["../../packages/ops/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
