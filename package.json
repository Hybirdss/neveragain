{
  "name": "namazue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @namazue/globe",
    "build": "npm run build -w @namazue/globe",
    "dev:worker": "npm run dev -w @namazue/worker",
    "build:data": "npx tsx tools/build-slab2-contours.ts && npx tsx tools/build-historical-catalog.ts",
    "test:boundaries": "node --test tools/tests/dependencyBoundaries.test.mjs",
    "check:boundaries": "node tools/check-dependency-boundaries.mjs",
    "check:worker": "npm run typecheck -w @namazue/worker && npm test -w @namazue/worker",
    "check:globe": "npm test -w @namazue/globe && npm run build -w @namazue/globe",
    "check": "npm run test:boundaries && npm run check:boundaries && npm run check:worker && npm run check:globe"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "pg": "^8.19.0"
  }
}
